<!DOCTYPE html>
<html lang="{{ report.lang|default('zh-TW') }}">
<head>
<meta charset="UTF-8">
<style>
  :root { --brand: {{ report.brand_color|default('#6c63ff') }}; --brand-dark: {{ report.brand_dark|default('#4b43c4') }}; --ink:#1f2430; --muted:#6b7280; --line:#e5e7eb; }
  * { box-sizing: border-box; }
  html, body { margin:0; padding:0; }
  body {
    font-family: "Noto Sans CJK TC","Noto Sans CJK SC","WenQuanYi Zen Hei","PingFang TC","Microsoft JhengHei","Helvetica Neue",Arial,sans-serif;
    color: var(--ink); font-size: 12px; line-height: 1.55; -webkit-print-color-adjust: exact; print-color-adjust: exact;
  }
  .page { page-break-after: always; padding: 0 16mm; }
  .page:last-child { page-break-after: auto; }

  /* ---------- Cover ---------- */
  .cover { padding: 0; page-break-after: always; }
  .cover-panel {
    background: var(--brand);
    color: #fff; height: 261mm; padding: 26mm 22mm; display: flex; flex-direction: column;
  }
  .cover-logo { margin-bottom: 9mm; }
  .cover-logo img { height: 72px; }   /* default; overridden inline by logo_height_px */
  .cover-brand { display: flex; flex-direction: column; gap: 2.5mm; }
  .cover-kicker { font-size: 13px; letter-spacing: 4px; text-transform: uppercase; opacity: .85; display: inline-block; }
  .cover-spacer { flex: 1; }
  .cover-title { font-size: 38px; font-weight: 800; line-height: 1.2; margin: 0 0 7mm; }
  .cover-sub { font-size: 17px; opacity: .92; margin-bottom: 14mm; max-width: 140mm; }
  .cover-meta { border-top: 1px solid rgba(255,255,255,.35); padding-top: 7mm; font-size: 14px; opacity: .95; }
  .cover-meta div { margin: 3px 0; }
  .cover-badge { display:inline-block; background:#ff9800; color:#3a2600; font-weight:700; font-size:10px; letter-spacing:1px; padding:2px 8px; border-radius:4px; vertical-align:middle; margin-left:8px; }

  /* ---------- Section / content ---------- */
  h1.section { font-size: 20px; font-weight: 800; color: var(--ink); margin: 10mm 0 2mm; padding-bottom: 3mm; border-bottom: 3px solid var(--brand); }
  h2.widget { font-size: 14px; font-weight: 700; margin: 0 0 2mm; color: var(--ink); }
  .desc { color: var(--muted); font-size: 11px; margin: 0 0 3mm; }
  .toc-title, .summary-title { font-size: 20px; font-weight: 800; margin: 10mm 0 4mm; padding-bottom: 3mm; border-bottom: 3px solid var(--brand); }
  .toc-item { display:flex; justify-content:space-between; padding: 3mm 0; border-bottom: 1px dotted var(--line); font-size: 13px; }
  .toc-item .n { color: var(--brand); font-weight: 700; margin-right: 10px;
    display: inline-block; min-width: 30px; text-align: right;
    flex: 0 0 auto; white-space: nowrap; }
  .toc-item > span { display: flex; align-items: baseline; }

  .card { border: 1px solid var(--line); border-radius: 8px; padding: 6mm; margin: 3mm 0 6mm; page-break-inside: avoid; }
  /* Definite heights are REQUIRED: with Chart.js maintainAspectRatio:false a
     height:auto / min-height container makes the canvas and container grow each
     other in a loop until the renderer OOM-crashes. A many-series legend gets a
     taller definite tier instead (.legend-heavy), which fits the legend. */
  .chart-wrap { position: relative; width: 100%; height: 62mm; }
  .chart-wrap.tall { height: 78mm; }
  .chart-wrap.legend-heavy { height: 110mm; }
  .map-wrap { width: 100%; border: 1px solid var(--line); border-radius: 6px; overflow: hidden; line-height: 0; }
  .map-wrap svg { width: 100%; height: auto; display: block; }
  .single-value { text-align:center; padding: 8mm 0; }
  .single-value .v { font-size: 40px; font-weight: 800; color: var(--brand); }
  .single-value .l { font-size: 12px; color: var(--muted); margin-top: 2mm; }
  .trend { display: inline-block; margin-top: 3mm; padding: 2px 10px; border-radius: 12px; font-size: 12px; font-weight: 700; }
  .trend-good { background: #e6f4ea; color: #1e7e34; }
  .trend-bad { background: #fdecea; color: #c62828; }
  .trend-neutral { background: #eef0f3; color: #5f6672; }
  .widget-range { font-size: 10px; color: var(--muted); text-align: right; margin-top: 2mm; }

  /* Auto layout everywhere = best-fit column widths (not averaged). The
     message-table max-columns setting guards against pathologically wide
     tables; word-break lets long cell values wrap instead of overflowing. */
  table.data { width:100%; border-collapse: collapse; font-size: 11px; table-layout: auto; }
  table.data th { background: #f3f4f6; text-align:left; padding: 5px 8px; border-bottom: 1.5px solid #b6bcc7; font-weight:700; }
  table.data td { padding: 5px 8px; border-bottom: 1px solid var(--line); }
  table.data th, table.data td { overflow-wrap: anywhere; word-break: break-word; }
  table.data tr:nth-child(even) td { background:#fafafa; }
  table.data th.num, table.data td.num { text-align: right; font-variant-numeric: tabular-nums; }
  /* Wide message tables: shrink font so more columns fit within the page. */
  table.data.wide { font-size: 9px; }
  table.data.wide th, table.data.wide td { padding: 3px 5px; }

  /* Heatmap grid (row-pivot × column-pivot, colour-graded cells) */
  .heat-scroll { width: 100%; overflow: hidden; }
  /* width:auto (not 100%) so the value columns stay as narrow as their fixed
     width instead of stretching to fill the page — a vertical header only needs
     the font's thickness, so the grid can be compact. */
  table.heat { width: auto; max-width: 100%; border-collapse: collapse; font-size: 10px; table-layout: fixed; }
  /* Keep the header row + first column as compact as possible so the coloured
     value cells get the most space. */
  table.heat th { background: #f3f4f6; font-weight: 600; padding: 2px 3px; border: 1px solid var(--line);
                  text-align: center; font-size: 8px; white-space: nowrap; }
  table.heat th.heat-row, table.heat th.heat-corner { width: 19mm; }
  table.heat th.heat-row { text-align: left; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 8px; padding: 2px 6px 2px 2px; }
  table.heat th.heat-corner { background: #fff; border: none; }
  /* Long column-category names in narrow columns → render vertical so they
     don't overlap each other. */
  table.heat th.col-hdr { writing-mode: vertical-rl; transform: rotate(180deg);
     white-space: nowrap; vertical-align: bottom; text-align: left; height: 30mm;
     width: 5.5mm; padding: 2px 0; }
  /* Grouped-row separator: a stronger line where a new top-level key begins. */
  table.data tr.grp-start td { border-top: 1.5px solid #c7ccd6; }
  /* Message preview (Graylog "Show message in new row"): the full message text
     sits on a second line UNDER its own entry, forming ONE visual row — the
     fields row drops its bottom border so it joins the message line, and the
     separator falls after the message instead of between them. */
  table.data tr.has-preview > td { border-bottom: 0; padding-bottom: 1px; }
  table.data tr.msg-preview td { border-top: 0; padding-top: 0; padding-bottom: 6px;
    color: #1f6feb; font-family: "DejaVu Sans Mono", "Courier New", monospace;
    font-size: 8px; line-height: 1.35; white-space: pre-wrap; word-break: break-all; }
  table.heat td { padding: 4px 1px; border: 1px solid #fff; text-align: center; font-variant-numeric: tabular-nums; }
  table.heat.wide { font-size: 8px; }
  table.heat.wide th, table.heat.wide td { padding: 2px 3px; }
  /* One tidy caption line: colour scale on the left, truncation note beside it. */
  .heat-footer { display: flex; align-items: center; margin-top: 2.5mm; gap: 4mm; font-size: 9px; color: var(--muted); }
  .heat-note { font-size: 9px; color: var(--muted); }
  .heat-legend { display: inline-flex; align-items: center; gap: 5px; }
  .heat-legend-bar { display: inline-block; width: 30mm; height: 2.6mm; border-radius: 2px; border: 1px solid var(--line); }
  .rows-note { font-size: 9px; color: var(--muted); text-align: right; margin-top: 2mm; }

  .shot { width: 100%; border: 1px solid var(--line); border-radius: 6px; margin: 3mm 0 6mm; page-break-inside: avoid; }
  .page-break { page-break-after: always; break-after: page; height: 0; }
  .summary p { font-size: 12px; }
  .kpi-row { display:flex; gap: 6mm; margin: 4mm 0; }
  .kpi { flex:1; border:1px solid var(--line); border-radius:8px; padding:5mm; text-align:center; }
  .kpi .v { font-size: 26px; font-weight:800; color: var(--brand); }
  .kpi .l { font-size: 11px; color: var(--muted); margin-top: 2mm; }
  .empty { color: var(--muted); font-size: 12px; font-style: italic; }
</style>
</head>
<body>

  <!-- Cover -->
  <div class="cover">
    <div class="cover-panel">
      <div class="cover-logo">{% if report.logo_data_uri %}<img src="{{ report.logo_data_uri }}" alt="" style="height:{{ report.logo_height_px | default(72) }}px">{% endif %}</div>
      <div class="cover-brand">
        <div class="cover-kicker">{{ report.kicker|default('Graylog Open Archive') }}</div>
      </div>
      <div class="cover-spacer"></div>
      <div class="cover-title">{{ report.title }}{% if report.beta %}<span class="cover-badge">BETA</span>{% endif %}</div>
      {% if report.subtitle %}<div class="cover-sub">{{ report.subtitle }}</div>{% endif %}
      <div class="cover-meta">
        {% if report.period %}<div>{{ t.period }}: {{ report.period }}</div>{% endif %}
        <div>{{ t.generated }}: {{ report.generated_at }}</div>
        {% if report.author %}<div>{{ t.author }}: {{ report.author }}</div>{% endif %}
        {% if report.server %}<div>{{ t.server }}: {{ report.server }}</div>{% endif %}
        {% if report.app_version %}<div>{{ t.system }}: jt-glogarch v{{ report.app_version }}</div>{% endif %}
      </div>
    </div>
  </div>

  <!-- Table of contents -->
  {% if toc %}
  <div class="page">
    <div class="toc-title">{{ t.toc }}</div>
    {% for item in toc %}
    <div class="toc-item"><span><span class="n">{{ loop.index }}.</span>{{ item }}</span></div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Executive summary -->
  {% if report.summary %}
  <div class="page summary">
    <div class="summary-title">{{ t.summary }}</div>
    {% if report.kpis %}<div class="kpi-row">{% for k in report.kpis %}<div class="kpi"><div class="v">{{ k.value }}</div><div class="l">{{ k.label }}</div></div>{% endfor %}</div>{% endif %}
    <div>{{ report.summary|safe }}</div>
  </div>
  {% endif %}

  <!-- Sections -->
  {% for sec in sections %}
  <div class="page">
    <h1 class="section">{{ sec.title }}</h1>
    {% if sec.description %}<div class="desc">{{ sec.description }}</div>{% endif %}

    {% if sec.type == 'image' %}
      {% if sec.img_slices %}
        {% for s in sec.img_slices %}<img class="shot" src="{{ s }}" alt="">{% if not loop.last %}<div class="page-break"></div>{% endif %}{% endfor %}
      {% elif sec.img_data_uri %}<img class="shot" src="{{ sec.img_data_uri }}" alt="">{% else %}<div class="empty">⚠ {{ sec.capture_error|default(t.no_capture) }}</div>{% endif %}

    {% elif sec.type == 'charts' %}
      {% for w in sec.widgets %}
      <div class="card">
        <h2 class="widget">{{ w.title }}</h2>
        {% if w.description %}<div class="desc">{{ w.description }}</div>{% endif %}
        {% if w.kind == 'single' %}
          <div class="single-value"><div class="v">{{ w.value }}</div>{% if w.label %}<div class="l">{{ w.label }}</div>{% endif %}
            {% if w.trend %}<div class="trend trend-{{ w.trend.cls }}">{{ w.trend.arrow }} {{ w.trend.delta }}{% if w.trend.pct %} / {{ w.trend.pct }}{% endif %}</div>{% endif %}</div>
        {% elif w.kind == 'table' %}
          <table class="data{% if w.columns|length > 6 %} wide{% endif %}"><thead><tr>{% for c in w.columns %}<th{% if w.col_align and w.col_align[loop.index0] == 'num' %} class="num"{% elif w.col_align is not defined and w.numeric_from is defined and loop.index0 >= w.numeric_from %} class="num"{% endif %}>{{ c }}</th>{% endfor %}</tr></thead>
          <tbody>{% for row in w.rows %}{% set _cells = row.cells if row is mapping else row %}<tr class="{% if row is mapping and row.group and not loop.first %}grp-start {% endif %}{% if row is mapping and row.preview is defined and row.preview %}has-preview{% endif %}">{% for cell in _cells %}<td{% if w.col_align and w.col_align[loop.index0] == 'num' %} class="num"{% elif w.col_align is not defined and w.numeric_from is defined and loop.index0 >= w.numeric_from %} class="num"{% endif %}>{{ cell }}</td>{% endfor %}</tr>{% if row is mapping and row.preview is defined and row.preview %}<tr class="msg-preview"><td colspan="{{ w.columns|length }}">{{ row.preview }}</td></tr>{% endif %}{% endfor %}</tbody></table>
          {% if w.rows_note %}<div class="rows-note">{{ w.rows_note }}</div>{% endif %}
        {% elif w.kind == 'map' %}
          <div class="map-wrap">{{ w.svg | safe }}</div>
        {% elif w.kind == 'heatmap' %}
          <div class="heat-scroll"><table class="heat{% if w.wide %} wide{% endif %}">
            <thead><tr><th class="heat-corner"></th>{% for c in w.columns %}<th class="col-hdr">{{ c }}</th>{% endfor %}</tr></thead>
            <tbody>{% for row in w.rows %}<tr><th class="heat-row">{{ row.label }}</th>{% for cell in row.cells %}<td style="background:{{ cell.bg }};color:{{ cell.fg }}">{{ cell.text }}</td>{% endfor %}</tr>{% endfor %}</tbody>
          </table></div>
          <div class="heat-footer">
            {% if w.legend_gradient %}<span class="heat-legend"><span>{{ w.legend_min }}</span><span class="heat-legend-bar" style="background:{{ w.legend_gradient }}"></span><span>{{ w.legend_max }}</span></span>{% endif %}
            {% if w.truncated %}<span class="heat-note">· {{ t.heat_truncated|default('僅顯示數值最高的列與欄') }}</span>{% endif %}
          </div>
        {% elif w.kind == 'chart' %}
          <div class="chart-wrap{% if w.tall %} tall{% endif %}{% if w.legend_heavy %} legend-heavy{% endif %}"><canvas id="{{ w.canvas_id }}"></canvas></div>
        {% else %}
          <div class="empty">{{ t.no_data }}</div>
        {% endif %}
        {% if w.range_label %}<div class="widget-range">🕒 {{ w.range_label }}</div>{% endif %}
      </div>
      {% endfor %}
    {% endif %}
  </div>
  {% endfor %}

  <script>{{ chartjs_src|safe }}</script>
  <script>
    Chart.defaults.font.family = getComputedStyle(document.body).fontFamily;
    Chart.defaults.font.size = 11;
    Chart.defaults.color = '#1f2430';
    Chart.defaults.animation = false;
    function fmtUnit(v, unit) {
      if (unit == null || typeof v !== 'number') return v;
      if (unit.unit_type === 'size') {
        let n = Math.abs(v), neg = v < 0, u = ['B','KB','MB','GB','TB','PB'], i = 0;
        while (n >= 1000 && i < u.length - 1) { n /= 1000; i++; }
        return (neg ? '-' : '') + (i === 0 ? n.toFixed(0) : n.toFixed(1)) + ' ' + u[i];
      }
      if (unit.unit_type === 'percent') return v.toFixed(1) + '%';
      return v;
    }
    // Draw percentage labels on pie/doughnut slices (like Graylog). Opt-in via
    // options.plugins.pctLabels=true. Only labels slices with room for the text
    // so thin slices don't overlap ("show if room").
    const pctLabelsPlugin = {
      id: 'pctLabels',
      afterDatasetsDraw(chart, args, opts) {
        if (!opts) return;
        const type = chart.config.type;
        if (type !== 'pie' && type !== 'doughnut') return;
        const ds = chart.data.datasets[0]; if (!ds) return;
        const vals = ds.data.map(v => Number(v) || 0);
        const total = vals.reduce((a, b) => a + b, 0);
        if (!total) return;
        const meta = chart.getDatasetMeta(0);
        const ctx = chart.ctx;
        ctx.save();
        ctx.font = '600 11px ' + Chart.defaults.font.family;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        meta.data.forEach((arc, i) => {
          const pct = vals[i] / total * 100;
          if (!isFinite(pct)) return;   // render 0% too (Graylog shows zero-value slices)
          const label = parseFloat(pct.toPrecision(3)) + '%';
          // Geometric fit test: the label must physically fit inside the slice —
          // its chord width at the ring mid-radius, and the ring thickness (this
          // is a doughnut). Skips slices with no room, matching Graylog.
          const pr = arc.getProps(['innerRadius', 'outerRadius', 'startAngle', 'endAngle'], true);
          const sweep = Math.abs(pr.endAngle - pr.startAngle);
          const midR = (pr.innerRadius + pr.outerRadius) / 2;
          // Horizontal room at the label position: for a slice ≥180° there is
          // effectively unlimited room; otherwise it's the chord across the arc
          // at the ring mid-radius. (Using the raw endpoint chord alone wrongly
          // reports ~0 for a near-full slice.)
          const room = sweep >= Math.PI ? Infinity : 2 * midR * Math.sin(sweep / 2);
          const tw = ctx.measureText(label).width, th = 11;
          if (room < tw + 4 || (pr.outerRadius - pr.innerRadius) < th + 2) return;
          const p = arc.getCenterPoint();
          // Pick black or white label for contrast against THIS slice's colour,
          // like Graylog (not always white). Normalise the colour via the canvas,
          // then luminance → threshold 150 (same rule as the heatmap cells).
          const col = (arc.options && arc.options.backgroundColor)
                      || (Array.isArray(ds.backgroundColor) ? ds.backgroundColor[i] : ds.backgroundColor) || '#888';
          ctx.fillStyle = col;
          const cs = ctx.fillStyle;
          let cr = 136, cg = 136, cb = 136;
          if (cs[0] === '#') { cr = parseInt(cs.slice(1, 3), 16); cg = parseInt(cs.slice(3, 5), 16); cb = parseInt(cs.slice(5, 7), 16); }
          else { const m = cs.match(/\d+/g); if (m) { cr = +m[0]; cg = +m[1]; cb = +m[2]; } }
          const dark = (0.299 * cr + 0.587 * cg + 0.114 * cb) > 150;
          ctx.lineWidth = 2.5;
          ctx.strokeStyle = dark ? 'rgba(255,255,255,0.6)' : 'rgba(0,0,0,0.4)';
          ctx.strokeText(label, p.x, p.y);
          ctx.fillStyle = dark ? '#1f2430' : '#ffffff';
          ctx.fillText(label, p.x, p.y);
        });
        ctx.restore();
      }
    };
    Chart.register(pctLabelsPlugin);

    // Time-axis day-boundary labels arrive as "HH:MM\nMM-DD"; Chart.js renders a
    // string with \n on one line, but a ticks.callback returning an ARRAY renders
    // multi-line. Use a real function so `this` is the scale (getLabelForValue);
    // wrap any existing callback so non-time labels pass through untouched.
    function _multilineTicks(orig) {
      return function (val, index, ticks) {
        const v = orig ? orig.call(this, val, index, ticks) : this.getLabelForValue(val);
        return (typeof v === 'string' && v.includes('\n')) ? v.split('\n') : v;
      };
    }

    const CHARTS = {{ charts_json|safe }};
    for (const c of CHARTS) {
      const el = document.getElementById(c.canvas_id);
      if (!el) continue;
      // Multi-line category-axis labels (time pivots with a day boundary).
      // Pie/doughnut have no axes; a horizontal bar's category axis is 'y'.
      if (c.config.type !== 'pie' && c.config.type !== 'doughnut') {
        const o = c.config.options = c.config.options || {};
        const s = o.scales = o.scales || {};
        const catAxis = (c.config.type === 'bar' && o.indexAxis === 'y') ? 'y' : 'x';
        s[catAxis] = s[catAxis] || {};
        s[catAxis].ticks = s[catAxis].ticks || {};
        s[catAxis].ticks.callback = _multilineTicks(s[catAxis].ticks.callback);
      }
      // Format the value axis with the widget's Graylog unit (bytes → GB, …).
      if (c.unit) {
        const o = c.config.options = c.config.options || {};
        const s = o.scales = o.scales || {};
        const ax = (c.config.data && c.config.data.labels && c.config.type === 'bar'
                    && c.config.options && c.config.options.indexAxis === 'y') ? 'x' : 'y';
        s[ax] = s[ax] || {};
        s[ax].ticks = s[ax].ticks || {};
        s[ax].ticks.callback = (val) => fmtUnit(val, c.unit);
        o.plugins = o.plugins || {};
        o.plugins.tooltip = o.plugins.tooltip || {};
        o.plugins.tooltip.callbacks = { label: (ctx) => fmtUnit(ctx.parsed[ax], c.unit) };
      }
      try { new Chart(el.getContext('2d'), c.config); } catch (e) { console.error(e); }
    }
  </script>
</body>
</html>
